   284	if [ "$FAILURES" -eq 0 ]; then
   285	  echo "PASS: AgentShield harness doctor"
   286	  exit 0
   287	fi
   288	
   289	echo "FAIL: AgentShield harness doctor found $FAILURES issue(s)" >&2
   290	exit 1

